// ── Toggle layer ──
function tog(key) {
  visible[key] = !visible[key];
  document.getElementById('b-'+key).classList.toggle('on', visible[key]);
  groups[key].forEach(item => {
    const show = visible[key];
    if (show) { item.marker.addTo(map); if(lblOn && item.label) item.label.addTo(map); }
    else { map.removeLayer(item.marker); if(item.label) map.removeLayer(item.label); }
    if (item.circle) {
      if (show && bufOn) item.circle.addTo(map);
      else map.removeLayer(item.circle);
    }
  });
}

function togBuf() {
  bufOn = !bufOn;
  document.getElementById('b-buf').classList.toggle('on', bufOn);
  Object.keys(groups).forEach(k => {
    groups[k].forEach(item => {
      if (!item.circle) return;
      if (bufOn && visible[k]) item.circle.addTo(map);
      else map.removeLayer(item.circle);
    });
  });
}

function togLabels() {
  lblOn = !lblOn;
  document.getElementById('b-lbl').classList.toggle('on', lblOn);
  Object.keys(groups).forEach(k => {
    groups[k].forEach(item => {
      if (!item.label) return;
      if (lblOn && visible[k]) item.label.addTo(map);
      else map.removeLayer(item.label);
    });
  });
}
</script>
