const COLORS = {
  '一級':'#ef4444','二級':'#f97316','三級':'#eab308',
  '四級':'#22c55e','非工措施':'#a855f7','未分類':'#94a3b8'
};
const BUF_ALPHA = {
  '一級':0.13,'二級':0.11,'三級':0.08,'四級':0.06,'非工措施':0.10,'未分類':0.06
};
const LVL_KEY = {'一級':'l1','二級':'l2','三級':'l3','四級':'l4','非工措施':'lx'};

const map = L.map('map',{zoomControl:true}).setView([23.05,120.22],11);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{
  attribution:'&copy; OpenStreetMap &copy; CARTO',
  subdomains:'abcd', maxZoom:19
}).addTo(map);

const groups = {l1:[],l2:[],l3:[],l4:[],lx:[],new:[],mov:[]};
let bufOn=true, lblOn=true;
const visible = {l1:true,l2:true,l3:true,l4:true,lx:true,new:true,mov:true};

function showInfo(title, html) {
  document.getElementById('ititle').textContent = title;
  document.getElementById('ibody').innerHTML = html;
  document.getElementById('ipanel').style.display = 'block';
}
function row(lbl,val) {
  return val && val!=='nan' && val!=='0.0' && val!==''
    ? `<div class="info-row"><div class="info-lbl">${lbl}</div><div class="info-val">${val}</div></div>` : '';
}

// ── Flood markers ──
FLOOD.forEach(pt => {
  const c = COLORS[pt.level]||'#94a3b8';
  const grp = LVL_KEY[pt.level]||'l3';
  const sz = pt.level==='一級'?10:pt.level==='二級'?9:8;

  // Dot marker
  const icon = L.divIcon({
    className:'',
    html:`<div style="width:${sz*2}px;height:${sz*2}px;border-radius:50%;background:${c};border:2px solid rgba(255,255,255,0.5);box-shadow:0 0 6px ${c}88;cursor:pointer"></div>`,
    iconSize:[sz*2,sz*2], iconAnchor:[sz,sz]
  });
  const m = L.marker([pt.y,pt.x],{icon,zIndexOffset:pt.level==='一級'?100:0}).addTo(map);
  m.on('click',()=>showInfo(pt.name,
    row('等級',`<span class="badge" style="background:${c}22;color:${c};border-color:${c}55">${pt.level}</span>`) +
    row('項次',pt.no)+row('行政區',pt.district)+row('地點',pt.location)+
    row('淹水高度',pt.height!=='nan'?pt.height+' 公分':null)+
    row('積淹面積',pt.area!=='nan'&&pt.area!=='0.0'?pt.area+' ha':null)+
    row('座標',pt.x.toFixed(5)+', '+pt.y.toFixed(5))
  ));

  // Label — 災點名稱，置於marker上方
  const labelText = pt.name.length>8 ? pt.name.slice(0,8)+'…' : pt.name;
  const lbl = L.marker([pt.y,pt.x],{
    icon: L.divIcon({
      className:'flood-label',
      html:`<div style="color:${c};text-shadow:0 0 4px #000,0 0 4px #000,1px 1px 3px #000;font-size:10px;font-weight:700;white-space:nowrap;pointer-events:none">${labelText}</div>`,
      iconSize:[0,0], iconAnchor:[-sz-2, sz+2]
    }),
    interactive:false, zIndexOffset:-100
  }).addTo(map);

  // Buffer
  const circle = L.circle([pt.y,pt.x],{
    radius:500, color:c, weight:1, opacity:0.4,
    fillColor:c, fillOpacity:BUF_ALPHA[pt.level]||0.08
  }).addTo(map);

  groups[grp].push({marker:m, label:lbl, circle});
});

